generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  TRADER
  INSTRUCTOR
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseCategory {
  BASICS
  FOREX
  CRYPTO
  STOCKS
  RISK_MANAGEMENT
  TECHNICAL_ANALYSIS
  FUNDAMENTAL_ANALYSIS
  PSYCHOLOGY
  OPTIONS
  COMMODITIES
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum CertificateStatus {
  ISSUED
  PRINTING
  SHIPPED
  DELIVERED
}

enum BrokerRegulation {
  FCA
  ASIC
  CySEC
  NFA
  FSCA
  SEC
  OTHER
  UNREGULATED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FundRecoveryStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SiteLocale {
  en
  ar
  es
  fr
}

// ─── USERS & AUTH ────────────────────────────────────────────────────────────

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  emailVerified      DateTime?
  passwordHash       String?
  name               String
  username           String?          @unique
  avatarUrl          String?
  bio                String?
  country            String?
  phone              String?
  preferredLocale    SiteLocale       @default(en)
  role               Role             @default(TRADER)
  subscription       SubscriptionTier @default(FREE)
  subscriptionEndsAt DateTime?
  isVerifiedTrader   Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  accounts          Account[]
  sessions          Session[]
  enrollments       Enrollment[]
  certificates      Certificate[]
  brokerReviews     BrokerReview[]
  savedBrokers      SavedBroker[]
  quizAttempts      QuizAttempt[]
  fundRecoveryCases FundRecoveryCase[]
  lessonProgress    LessonProgress[]

  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── COURSES & EDUCATION ─────────────────────────────────────────────────────

model Course {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  titleAr         String?
  titleEs         String?
  titleFr         String?
  description     String         @db.Text
  descriptionAr   String?        @db.Text
  descriptionEs   String?        @db.Text
  descriptionFr   String?        @db.Text
  thumbnailUrl    String?
  previewVideoUrl String?
  category        CourseCategory
  level           CourseLevel
  isPremium       Boolean        @default(false)
  isPublished     Boolean        @default(false)
  totalDuration   Int            @default(0)
  totalLessons    Int            @default(0)
  instructor      String?
  tags            String[]
  metaTitle       String?
  metaDescription String?
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([slug])
  @@index([category])
  @@index([isPremium])
  @@index([isPublished])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  titleAr   String?
  titleEs   String?
  titleFr   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id        String     @id @default(cuid())
  moduleId  String
  title     String
  titleAr   String?
  titleEs   String?
  titleFr   String?
  type      LessonType
  content   String?    @db.Text
  contentAr String?    @db.Text
  contentEs String?    @db.Text
  contentFr String?    @db.Text
  videoUrl  String?
  duration  Int?
  isFree    Boolean    @default(false)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())

  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz           Quiz?
  lessonProgress LessonProgress[]

  @@index([moduleId])
}

model Quiz {
  id        String   @id @default(cuid())
  lessonId  String   @unique
  passMark  Int      @default(70)
  createdAt DateTime @default(now())

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String  @id @default(cuid())
  quizId        String
  question      String
  questionAr    String?
  questionEs    String?
  questionFr    String?
  options       Json
  correctOption String
  explanation   String?
  sortOrder     Int     @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  answers     Json
  score       Int
  passed      Boolean
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  progressPct Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Certificate {
  id              String            @id @default(cuid())
  userId          String
  courseId        String
  certificateCode String            @unique @default(cuid())
  issuedAt        DateTime          @default(now())
  status          CertificateStatus @default(ISSUED)
  shippingAddress Json?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([certificateCode])
}

// ─── BROKERS ─────────────────────────────────────────────────────────────────

model Broker {
  id                   String           @id @default(cuid())
  slug                 String           @unique
  name                 String
  logoUrl              String?
  websiteUrl           String?
  description          String           @db.Text
  descriptionAr        String?          @db.Text
  descriptionEs        String?          @db.Text
  descriptionFr        String?          @db.Text
  regulation           BrokerRegulation @default(OTHER)
  regulatoryBody       String?
  licenseNumber        String?
  founded              Int?
  headquarters         String?
  minDeposit           Decimal?         @db.Decimal(10, 2)
  maxLeverage          String?
  spreadsFrom          Decimal?         @db.Decimal(10, 5)
  platforms            String[]
  instruments          String[]
  accountTypes         Json?
  withdrawalMethods    String[]
  customerSupportHours String?
  isVerified           Boolean          @default(false)
  isFeatured           Boolean          @default(false)
  isBlacklisted        Boolean          @default(false)
  overallRating        Decimal          @default(0) @db.Decimal(3, 2)
  totalReviews         Int              @default(0)
  ratingTrustScore     Decimal          @default(0) @db.Decimal(3, 2)
  ratingPlatform       Decimal          @default(0) @db.Decimal(3, 2)
  ratingSupport        Decimal          @default(0) @db.Decimal(3, 2)
  ratingFees           Decimal          @default(0) @db.Decimal(3, 2)
  ratingWithdrawal     Decimal          @default(0) @db.Decimal(3, 2)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  reviews BrokerReview[]
  savedBy SavedBroker[]

  @@index([slug])
  @@index([overallRating])
  @@index([isBlacklisted])
  @@index([isFeatured])
}

model BrokerReview {
  id                String       @id @default(cuid())
  brokerId          String
  userId            String
  title             String
  content           String       @db.Text
  rating            Int
  ratingTrust       Int
  ratingPlatform    Int
  ratingSupport     Int
  ratingFees        Int
  ratingWithdrawal  Int
  tradingExperience Int?
  accountType       String?
  country           String?
  status            ReviewStatus @default(PENDING)
  isVerified        Boolean      @default(false)
  helpfulCount      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brokerId])
  @@index([brokerId, status])
  @@index([userId])
}

model SavedBroker {
  id       String   @id @default(cuid())
  userId   String
  brokerId String
  savedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@unique([userId, brokerId])
  @@index([userId])
}

// ─── FUND RECOVERY ───────────────────────────────────────────────────────────

model FundRecoveryCase {
  id           String             @id @default(cuid())
  userId       String?
  name         String
  email        String
  phone        String?
  country      String?
  brokerName   String
  amountLost   Decimal?           @db.Decimal(12, 2)
  currency     String?            @default("USD")
  description  String             @db.Text
  evidenceUrls String[]
  status       FundRecoveryStatus @default(SUBMITTED)
  adminNotes   String?            @db.Text
  resolvedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
}

// ─── CONTENT & SETTINGS ──────────────────────────────────────────────────────

model ContactSubmission {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String     @db.Text
  locale    SiteLocale @default(en)
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String?
  avatarUrl String?
  content   String   @db.Text
  contentAr String?  @db.Text
  contentEs String?  @db.Text
  contentFr String?  @db.Text
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
