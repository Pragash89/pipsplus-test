# =============================================================================
# PipsPlus — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# For LOCAL development: your local PostgreSQL connection string
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/pipsplus"
#
# For VERCEL / production: use a cloud PostgreSQL provider.
# Recommended (free tier): https://neon.tech
#   1. Sign up at neon.tech → create a project → copy the connection string
#   2. Add it to Vercel: Project Settings → Environment Variables → DATABASE_URL
# Example Neon URL:
DATABASE_URL="postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# For LOCAL development:
# NEXTAUTH_URL="http://localhost:3000"
#
# For VERCEL: set this to your Vercel deployment URL, e.g.:
# NEXTAUTH_URL="https://pipsplus-test.vercel.app"
# (Vercel also exposes VERCEL_URL automatically, but NEXTAUTH_URL must be set explicitly)
NEXTAUTH_URL="https://your-deployment.vercel.app"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: https://your-deployment.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get an API key at https://resend.com — free tier supports 3,000 emails/month
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="noreply@pipsplus.com"

# ─── Public Variables ─────────────────────────────────────────────────────────
# For LOCAL:  NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# For Vercel: NEXT_PUBLIC_SITE_URL="https://your-deployment.vercel.app"
NEXT_PUBLIC_SITE_URL="https://your-deployment.vercel.app"
